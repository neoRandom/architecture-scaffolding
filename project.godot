config_version=5

[application]

config/name="Architecture Scaffolding"
run/main_scene="uid://c3hqfyupisitr"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/low_processor_mode=true
config/icon="res://icon.svg"

[autoload]

Command="*uid://807e1eeid10n"

[display]

